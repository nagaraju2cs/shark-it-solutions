# =============================================
# SHARK IT SOLUTIONS — ENVIRONMENT VARIABLES
# =============================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/sharkitsolutions
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/sharkitsolutions

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Email (Nodemailer — use Gmail or SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=info@sharkitsolutions.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=Shark IT Solutions <info@sharkitsolutions.com>

# Admin Email (receives contact form submissions)
ADMIN_EMAIL=admin@sharkitsolutions.com

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=5242880
